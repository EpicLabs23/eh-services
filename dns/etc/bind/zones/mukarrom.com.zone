$ORIGIN mukarrom.com.
$TTL 3600
@    IN    SOA    ns1.mukarrom.com. admin.mukarrom.com. (
            2023081801 ; Serial
            3600       ; Refresh
            1800       ; Retry
            604800     ; Expire
            86400      ; Minimum TTL
)

; Name servers
@    IN    NS    ns1.mukarrom.com.
@    IN    NS    ns2.mukarrom.com.

; A records
ns1    IN    A    127.0.0.1
ns2    IN    A    127.0.0.1

; Additional records


www    IN    A    192.168.1.2


